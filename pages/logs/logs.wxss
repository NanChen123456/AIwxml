.summary-scroll {
  height: calc(100vh - 88px);
}

.summary-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.error-card,
.list-card,
.empty-card {
  padding: 28rpx;
}

.error-card {
  background: rgba(178, 79, 67, 0.1);
}

.error-text,
.empty-text,
.row-count {
  font-size: 24rpx;
  color: #7a6855;
  line-height: 1.6;
}

.login-nav-button {
  margin-top: 24rpx;
  width: 100%;
}

.summary-head {
  color: #a5512b;
  font-weight: 600;
  background: rgba(211, 111, 61, 0.1);
}

.summary-row {
  display: flex;
  align-items: center;
  padding: 20rpx 12rpx;
  border-bottom: 1rpx solid rgba(122, 104, 85, 0.12);
}

.summary-row:last-child {
  border-bottom: none;
}

.date-wrap {
  flex: 1.8;
  display: flex;
  flex-direction: column;
}

.date-col,
.metric-col {
  font-size: 24rpx;
}

.metric-col {
  flex: 1;
  text-align: center;
}